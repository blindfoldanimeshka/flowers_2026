# ===== ОСНОВНЫЕ НАСТРОЙКИ =====
NODE_ENV=production
PORT=3000

# ===== SUPABASE =====
SUPABASE_URL=https://jnbopvwnwyummzvsqjcj.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_COLLECTION_TABLE=documents

# ===== JWT НАСТРОЙКИ =====
JWT_SECRET=your_generated_jwt_secret_here

# ===== API НАСТРОЙКИ =====
NEXT_PUBLIC_API_URL=https://your-project.vercel.app

# ===== БЕЗОПАСНОСТЬ =====
ALLOWED_ORIGINS=https://your-project.vercel.app,https://www.your-project.vercel.app

# ===== ПРОДАКШЕН НАСТРОЙКИ =====
NEXT_DISABLE_FONT_DOWNLOAD=1
NEXT_TELEMETRY_DISABLED=1

# ===== ЛОГИРОВАНИЕ =====
LOG_LEVEL=info
ENABLE_DEBUG_LOGS=false

# ===== RATE LIMITING =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===== ПЛАТЕЖИ (опционально) =====
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# YOOKASSA_SECRET_KEY=your_yookassa_key
# SBERBANK_API_KEY=your_sberbank_key
