{
  "name": "flower-production",
  "version": "1.0.0",
  "description": "Система управления производством цветов с админ-панелью и клиентской частью",
  "private": true,
  "author": "Flower Production Team",
  "license": "MIT",
  "keywords": [
    "nextjs",
    "react",
    "typescript",
    "supabase",
    "flowers",
    "ecommerce"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:db": "node test-app.js",
    "db:seed": "node seed-data.js",
    "db:create-admin": "node create-admin.js",
    "generate-secrets": "node generate-secrets.js",
    "health-check": "node scripts/health-check.js",
    "setup": "node scripts/setup.js",
    "deploy": "node scripts/deploy.js",
    "clean": "rm -rf .next node_modules/.cache",
    "preview": "npm run build && npm run start"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.58.0",
    "bcryptjs": "^3.0.2",
    "concurrently": "^9.2.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.1",
    "framer-motion": "^12.23.12",
    "jose": "^6.0.11",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.545.0",
    "next": "^16.1.7",
    "node-fetch": "^2.7.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-dropzone": "^14.3.8",
    "react-icons": "^5.5.0",
    "react-imask": "^7.6.1",
    "react-input-mask": "^2.0.4",
    "react-toastify": "^11.0.5",
    "slugify": "^1.6.6",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "critters": "^0.0.23",
    "eslint": "^9.37.0",
    "eslint-config-next": "^15.5.14",
    "image-webpack-loader": "^8.1.0",
    "jest": "^30.2.0",
    "tailwindcss": "^4.0.0",
    "ts-jest": "^29.4.5",
    "typescript": "^5.9.3"
